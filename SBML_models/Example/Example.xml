<?xml version="1.0" encoding="UTF-8"?>
<sbml xmlns="http://www.sbml.org/sbml/level3/version2/core" level="3" version="2">
  <model metaid="__main" id="__main">
    <listOfCompartments>
      <compartment id="Comp1" spatialDimensions="3" constant="true"/>
    </listOfCompartments>
    <listOfSpecies>
      <species id="A_Comp1" compartment="Comp1" initialAmount="0" hasOnlySubstanceUnits="true" boundaryCondition="false" constant="false"/>
      <species id="B_Comp1" compartment="Comp1" initialAmount="0" hasOnlySubstanceUnits="true" boundaryCondition="false" constant="false"/>
    </listOfSpecies>
    <listOfParameters>
      <parameter id="V_Comp1" value="1" constant="true"/>
      <parameter id="k_A_to_B" value="0.1" constant="true"/>
      <parameter id="pw_interp1" value="0" constant="false"/>
      <parameter id="pw_interp2" value="0" constant="false"/>
    </listOfParameters>
    <listOfInitialAssignments>
      <initialAssignment symbol="Comp1">
        <math xmlns="http://www.w3.org/1998/Math/MathML">
          <ci> V_Comp1 </ci>
        </math>
      </initialAssignment>
    </listOfInitialAssignments>
    <listOfRules>
      <assignmentRule variable="pw_interp1">
        <math xmlns="http://www.w3.org/1998/Math/MathML">
          <cn type="integer"> 0 </cn>
        </math>
      </assignmentRule>
      <assignmentRule variable="pw_interp2">
        <math xmlns="http://www.w3.org/1998/Math/MathML">
          <cn type="integer"> 0 </cn>
        </math>
      </assignmentRule>
    </listOfRules>
    <listOfReactions>
      <reaction id="Basic_A_to_B_Comp1" reversible="true">
        <listOfReactants>
          <speciesReference species="A_Comp1" stoichiometry="1" constant="true"/>
        </listOfReactants>
        <listOfProducts>
          <speciesReference species="B_Comp1" stoichiometry="1" constant="true"/>
        </listOfProducts>
        <kineticLaw>
          <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
              <times/>
              <ci> k_A_to_B </ci>
              <apply>
                <divide/>
                <ci> A_Comp1 </ci>
                <ci> V_Comp1 </ci>
              </apply>
              <ci> V_Comp1 </ci>
            </apply>
          </math>
        </kineticLaw>
      </reaction>
    </listOfReactions>
    <listOfEvents>
      <event id="_E0" useValuesFromTriggerTime="true">
        <trigger initialValue="true" persistent="true">
          <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
              <geq/>
              <csymbol encoding="text" definitionURL="http://www.sbml.org/sbml/symbols/time"> time </csymbol>
              <cn type="integer"> 10 </cn>
            </apply>
          </math>
        </trigger>
        <listOfEventAssignments>
          <eventAssignment variable="A_Comp1">
            <math xmlns="http://www.w3.org/1998/Math/MathML">
              <cn type="integer"> 5 </cn>
            </math>
          </eventAssignment>
        </listOfEventAssignments>
      </event>
    </listOfEvents>
